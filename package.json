    "@hugeicons/react": "^1.1.9",
    "@neondatabase/serverless": "^1.1.0",
    "@tailwindcss/vite": "^4",
    "@tanstack/react-query": "^5.101.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-router": "^8.2.0",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
